<Window x:Class="BurgerPlusUC.AuthorizationWindow.WindowAuthorization"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BurgerPlusUC.AuthorizationWindow"
        mc:Ignorable="d"
        Title="Авторизация" 
        Height="650" Width="900"
        MinHeight="650" MinWidth="900">
    <Grid>
        <!-- Панель авторизации -->
        <StackPanel x:Name="authPanel" Orientation="Vertical"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <TextBlock Text="Авторизация"
                   TextAlignment="Center"
                   FontSize="48"
                   FontFamily="Comic Sans MS"/>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Логин"
                       FontSize="25"
                       FontFamily="Comic Sans"
                       Margin="0,40" 
                       TextAlignment="Right"
                       Width="100"/>
                <TextBox Width="400"
                     Height="40"
                     FontSize="20"
                     Margin="10,0,0,0"
                     x:Name="loginBox"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Пароль"
                       FontSize="25"
                       FontFamily="Comic Sans" 
                       TextAlignment="Right"
                       Width="100"/>
                <PasswordBox Width="400"
                         Height="40"
                         FontSize="20"
                         Margin="10,0,0,0"
                         x:Name="passwordBox"/>
            </StackPanel>

            <Button Content="ВОЙТИ"
                FontSize="25"
                Width="150"
                FontFamily="Comic Sans MS"
                Margin="0,20" 
                Click="AuthorizationButton_Click"/>
        </StackPanel>

        <!-- ПАНЕЛЬ CAPTCHA (изначально скрыта) -->
        <StackPanel x:Name="captchaPanel" Orientation="Vertical"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="Collapsed">

            <TextBlock Text="Подтверждение"
                   FontSize="32"
                   FontFamily="Comic Sans MS"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,30"
                   Foreground="#333333"/>

            <TextBlock Text="Введите цифры с картинки:"
                   FontSize="18"
                   FontFamily="Comic Sans"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"
                   Foreground="#555555"/>
            <!-- Отображение CAPTCHA -->
            <Border x:Name="captchaBorder" 
                Width="250" 
                Height="80" 
                BorderBrush="Black" 
                BorderThickness="2"
                Background="White"
                CornerRadius="5"
                Margin="0,0,0,20"
                HorizontalAlignment="Center">
                <TextBlock x:Name="captchaTextBlock" 
                       Text="" 
                       FontSize="36" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       FontFamily="Arial"
                       Foreground="#2196F3"/>
            </Border>

            <TextBlock Text="Введите цифры:"
                   FontSize="16"
                   FontFamily="Comic Sans"
                   Margin="0,0,0,10"/>

            <TextBox x:Name="captchaInputBox"
                 Width="250"
                 Height="45"
                 FontSize="20"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,20"
                 TextAlignment="Center"
                 BorderBrush="Black"
                 BorderThickness="2"/>

            <Button x:Name="verifyButton"
                Content="ПРОВЕРИТЬ КАПЧУ"
                FontSize="20"
                Width="250"
                Height="50"
                FontFamily="Comic Sans MS"
                BorderThickness="0"
                Cursor="Hand"
                Margin="0,0,0,15"
                Click="VerifyButton_Click"/>

            <TextBlock x:Name="attemptsText"
                   Text="Осталось попыток: 3"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   Foreground="Red"/>
        </StackPanel>
    </Grid>
</Window>
