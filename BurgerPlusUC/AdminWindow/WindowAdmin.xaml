<Window x:Class="BurgerPlusUC.AdminWindow.WindowAdmin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BurgerPlusUC.AdminWindow"
        mc:Ignorable="d"
        Title="Рабочий стол Администратора"
        Height="600" Width="800"
        MinHeight="600" MinWidth="800">
    <Grid Background="White">
        <StackPanel Margin="20">
            <!-- Заголовок -->
            <TextBlock Text="Рабочий стол Администратора" 
                       FontFamily="Comic Sans MS" 
                       FontSize="24" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

            <!-- Таблица пользователей -->
            <DataGrid x:Name="dgUsers" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      SelectionMode="Single" 
                      Height="250"
                      Margin="0,0,0,20"
                      FontFamily="Comic Sans MS"
                      Background="White"
                      BorderBrush="Gray">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Логин" 
                                        Binding="{Binding user_login}" 
                                        Width="*" />
                    <DataGridTextColumn Header="Роль" 
                                        Binding="{Binding role.role_name}" 
                                        Width="*" />
                    <DataGridTextColumn Header="Заблокирован" 
                                        Binding="{Binding is_blocked}" 
                                        Width="100" />
                    <DataGridTextColumn Header="Неудачных попыток" 
                                        Binding="{Binding failed_attempts}" 
                                        Width="150" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Поля ввода -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Margin="0,0,0,10">
                <StackPanel Margin="5">
                    <TextBlock Text="Логин" 
                               FontFamily="Comic Sans MS"/>
                    <TextBox x:Name="tbLogin" 
                             Width="150" 
                             Height="30" 
                             FontFamily="Comic Sans MS"/>
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="Пароль" 
                               FontFamily="Comic Sans MS"/>
                    <PasswordBox x:Name="pbPassword" 
                                 Width="150" 
                                 Height="30" 
                                 FontFamily="Comic Sans MS"/>
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="Роль" 
                               FontFamily="Comic Sans MS"/>
                    <ComboBox x:Name="cbRole" 
                              Width="150" 
                              Height="30" 
                              FontFamily="Comic Sans MS"/>
                </StackPanel>
            </StackPanel>

            <!-- Кнопки действий -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center">
                <Button Content="Добавить пользователя" 
                        Width="200" 
                        Height="40" 
                        FontFamily="Comic Sans MS" 
                        FontSize="14" 
                        Margin="10" 
                        Click="BtnAdd_Click"/>

                <Button Content="Изменить данные" 
                        Width="200" 
                        Height="40" 
                        FontFamily="Comic Sans MS" 
                        FontSize="14" 
                        Margin="10" 
                        Click="BtnEdit_Click"/>

                <Button Content="Снять блокировку" 
                        Width="200" 
                        Height="40" 
                        FontFamily="Comic Sans MS" 
                        FontSize="14" 
                        Margin="10" 
                        Click="BtnUnblock_Click"/>
            </StackPanel>

            <!-- Кнопка выхода -->
            <Button Content="Выйти" 
                    Width="100" 
                    Height="30" 
                    FontFamily="Comic Sans MS" 
                    HorizontalAlignment="Center" 
                    Margin="0,20,0,0" 
                    Click="BtnExit_Click"/>
        </StackPanel>
    </Grid>
</Window>
